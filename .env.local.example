# Supabase — grab these from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, used by admin API routes
# NEVER expose this on the client. Vercel keeps it server-side automatically.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin password for the admin panel
ADMIN_PASSWORD=jdgames2026
